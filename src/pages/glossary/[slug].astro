---
import { getCollection, render } from 'astro:content';
import ContentCard from '../../components/ContentCard.astro';
import ConstitutionRefs from '../../components/ConstitutionRefs.astro';
import PageIntro from '../../components/PageIntro.astro';
import SearchSignals from '../../components/SearchSignals.astro';
import Layout from '../../layouts/Layout.astro';
import {
	filterByAnyRelationship,
	formatDate,
	getEntryHref,
	resolveBySlugs,
	sortByDateDesc,
	titleCaseStatus,
	uniqueBySlug,
} from '../../lib/content';

export async function getStaticPaths() {
	const glossary = await getCollection('glossary');
	return glossary.map((entry) => ({
		params: { slug: entry.data.slug },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const [articles, parts, schedules, topics, cases, currentAffairs, sources] = await Promise.all([
	getCollection('articles'),
	getCollection('parts'),
	getCollection('schedules'),
	getCollection('topics'),
	getCollection('cases'),
	getCollection('current-affairs'),
	getCollection('sources'),
]);

const relatedArticles = resolveBySlugs(articles, entry.data.relatedArticles);
const relatedParts = resolveBySlugs(parts, entry.data.relatedParts);
const relatedSchedules = resolveBySlugs(schedules, entry.data.relatedSchedules);
const relatedTopics = resolveBySlugs(topics, entry.data.topics);
const relatedCases = resolveBySlugs(cases, entry.data.cases);
const relatedCurrentAffairs = sortByDateDesc(
	uniqueBySlug([
		...filterByAnyRelationship(currentAffairs, 'articles', entry.data.relatedArticles),
		...filterByAnyRelationship(currentAffairs, 'topics', entry.data.topics),
		...filterByAnyRelationship(currentAffairs, 'cases', entry.data.cases),
	]),
	'updatedAt',
);
const relatedSources = resolveBySlugs(sources, entry.data.sources);
---

<Layout title={`${entry.data.title} | Constitution Atlas`} description={entry.data.summary} pagefindIndexed={true}>
	<PageIntro
		eyebrow="Glossary"
		title={entry.data.title}
		summary={entry.data.summary}
		meta={[entry.data.plainEnglish]}
		breadcrumbs={[
			{ label: 'Home', href: '/' },
			{ label: 'Glossary', href: '/glossary' },
			{ label: entry.data.title },
		]}
	/>
	<SearchSignals
		meta={{
			type: 'Glossary',
			summary: entry.data.summary,
			subtitle: entry.data.plainEnglish,
		}}
		filters={{
			type: 'Glossary',
			topic: relatedTopics.map((topic) => topic.data.title),
		}}
	/>

	<section class="page-grid">
		<article class="page-copy prose" data-pagefind-body>
			<section>
				<h2>Plain-English meaning</h2>
				<p>{entry.data.plainEnglish}</p>
			</section>
			<Content />
		</article>
		<aside class="page-sidebar">
			<ConstitutionRefs
				parts={relatedParts.map((part) => ({ title: part.data.code, href: getEntryHref('parts', part.data.slug) }))}
				schedules={relatedSchedules.map((schedule) => ({ title: `Schedule ${schedule.data.number}`, href: getEntryHref('schedules', schedule.data.slug) }))}
				articles={relatedArticles.map((article) => ({ title: `Article ${article.data.number}`, href: getEntryHref('articles', article.data.slug) }))}
			/>
			<div class="info-panel">
				<h3>Related Topics</h3>
				<div class="link-list">
					{relatedTopics.map((topic) => <a class="tag-chip" href={getEntryHref('topics', topic.data.slug)}>{topic.data.title}</a>)}
				</div>
			</div>
			<div class="info-panel">
				<h3>Sources</h3>
				<ul class="link-list">
					{
						relatedSources.map((source) => (
							<li>
								<a href={source.data.url} target="_blank" rel="noreferrer">{source.data.title}</a>
							</li>
						))
					}
				</ul>
			</div>
		</aside>
	</section>

	{relatedArticles.length > 0 && (
		<section class="section-block">
			<div class="section-heading">
				<div>
					<p class="eyebrow">Articles</p>
					<h2>Where the concept appears in the constitutional text</h2>
				</div>
			</div>
			<div class="card-grid">
				{
					relatedArticles.map((article) => (
						<ContentCard
							eyebrow={`Article ${article.data.number}`}
							title={article.data.title}
							description={article.data.summary}
							href={getEntryHref('articles', article.data.slug)}
							meta={article.data.part}
						/>
					))
				}
			</div>
		</section>
	)}

	{relatedCases.length > 0 && (
		<section class="section-block">
			<div class="section-heading">
				<div>
					<p class="eyebrow">Cases</p>
					<h2>Judgments that define the term</h2>
				</div>
			</div>
			<div class="card-grid">
				{
					relatedCases.map((item) => (
						<ContentCard
							eyebrow={item.data.year.toString()}
							title={item.data.title}
							description={item.data.summary}
							href={getEntryHref('cases', item.data.slug)}
							meta={item.data.citation}
						/>
					))
				}
			</div>
		</section>
	)}

	{relatedCurrentAffairs.length > 0 && (
		<section class="section-block">
			<div class="section-heading">
				<div>
					<p class="eyebrow">Current Affairs</p>
					<h2>Where the concept is currently contested</h2>
				</div>
			</div>
			<div class="card-grid">
				{
					relatedCurrentAffairs.map((item) => (
						<ContentCard
							eyebrow={titleCaseStatus(item.data.status)}
							title={item.data.title}
							description={item.data.summary}
							href={getEntryHref('current-affairs', item.data.slug)}
							meta={`Updated ${formatDate(item.data.updatedAt)}`}
						/>
					))
				}
			</div>
		</section>
	)}
</Layout>
