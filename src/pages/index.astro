---
import { getCollection } from 'astro:content';
import ContentCard from '../components/ContentCard.astro';
import GraphExplorer from '../components/GraphExplorer.astro';
import Layout from '../layouts/Layout.astro';
import { defaultGraphPresets } from '../lib/graph-presets';
import { buildGraphExplorerData } from '../lib/graph';
import {
	formatDate,
	getEntryHref,
	humanizeToken,
	sortArticles,
	sortByDateDesc,
	sortByNumericField,
	sortByTitle,
	titleCaseStatus,
	withBase,
} from '../lib/content';

const [articles, parts, schedules, topics, institutions, glossary, cases, amendments, timeline, currentAffairs, sources, edges] = await Promise.all([
	getCollection('articles'),
	getCollection('parts'),
	getCollection('schedules'),
	getCollection('topics'),
	getCollection('institutions'),
	getCollection('glossary'),
	getCollection('cases'),
	getCollection('amendments'),
	getCollection('timeline'),
	getCollection('current-affairs'),
	getCollection('sources'),
	getCollection('edges'),
]);

const featuredArticles = sortArticles(articles).slice(0, 4);
const featuredParts = sortByNumericField(parts, 'order').slice(0, 3);
const featuredSchedules = sortByNumericField(schedules, 'number').slice(0, 3);
const featuredTopics = sortByTitle(topics).slice(0, 4);
const featuredInstitutions = sortByTitle(institutions).slice(0, 4);
const featuredGlossary = sortByTitle(glossary).slice(0, 3);
const featuredCases = sortByTitle(cases).slice(0, 3);
const featuredAmendments = [...amendments].sort((left, right) => right.data.year - left.data.year).slice(0, 3);
const featuredTimeline = sortByDateDesc(timeline, 'date').slice(0, 4);
const latestCurrentAffairs = sortByDateDesc(currentAffairs, 'updatedAt').slice(0, 3);
const featuredSources = sortByTitle(sources).slice(0, 3);
const graph = buildGraphExplorerData({
	articles,
	parts,
	schedules,
	topics,
	institutions,
	cases,
	glossary,
	amendments,
	timeline,
	currentAffairs,
	edges,
}, { profile: 'home' });
---

<Layout
	title="Constitution Atlas | Indian Constitution Reference"
	description="A Wikipedia-style constitutional knowledge platform for the Indian Constitution, amendments, landmark cases, and current affairs."
>
	<section class="hero">
		<div class="hero-copy">
			<p class="eyebrow">Constitution Atlas</p>
			<h1>Indian constitutional law as one connected knowledge system.</h1>
			<p class="hero-text">
				Follow Articles, landmark cases, amendments, institutions, and live constitutional disputes through a
				linked graph built for serious reading, research, and explanation.
			</p>
			<form class="hero-search" action={withBase('/search')} method="get">
				<label class="sr-only" for="home-search">Search the site</label>
				<input
					id="home-search"
					type="search"
					name="q"
					placeholder="Search Article 21, Kesavananda, federalism..."
				/>
				<button type="submit">Search</button>
			</form>
			<div class="hero-actions">
				<a class="button-primary" href={withBase('/graph')}>Open the Knowledge Graph</a>
				<a class="button-secondary" href={withBase('/current-affairs')}>Track Current Affairs</a>
			</div>
		</div>
		<div class="hero-panel">
			<p class="panel-label">What makes this project different</p>
			<ul class="hero-list">
				<li>A live constitutional graph instead of disconnected article pages</li>
				<li>Current-affairs issue desks linked back to constitutional text and doctrine</li>
				<li>Amendment, timeline, and case layers that explain how meaning changed</li>
				<li>A source-backed reading model built around the Constitution itself</li>
			</ul>
		</div>
	</section>

	<section class="section-block section-block--graph-highlight">
		<div class="section-heading">
			<div>
				<p class="eyebrow">Highlight</p>
				<h2>The graph is the front door</h2>
			</div>
			<a class="section-link" href={withBase('/graph')}>Open the full Relationship Explorer</a>
		</div>
		<div class="graph-home-copy">
			<div class="search-result graph-home-callout">
				<p class="eyebrow">Constitutional Intelligence</p>
				<strong>Trace doctrine, amendment, history, and live disputes from one node</strong>
				<p>
					Start from Article 21, Kesavananda Bharati, the Election Commission, or an active controversy, then
					follow the shortest constitutional path across the site. This is the fastest way to understand why a
					page matters and what it is connected to.
				</p>
			</div>
			<div class="graph-home-metrics">
				<div class="stat-card">
					<strong>{graph.nodes.length}</strong>
					<span>Indexed nodes</span>
				</div>
				<div class="stat-card">
					<strong>{graph.edges.length}</strong>
					<span>Typed relationships</span>
				</div>
				<div class="stat-card">
					<strong>{graph.legend.length}</strong>
					<span>Relationship families</span>
				</div>
				<div class="stat-card">
					<strong>{graph.edges.filter((edge) => edge.explicit).length}</strong>
					<span>Explicit doctrine links</span>
				</div>
			</div>
		</div>
	</section>

	<GraphExplorer
		nodes={graph.nodes}
		edges={graph.edges}
		stats={graph.stats}
		legend={graph.legend}
		variant="home"
		eyebrow="Knowledge Graph"
		title="See constitutional ideas as a living network"
		summary="The homepage graph is a curated constitutional backbone: landmark doctrine, formal constitutional anchors, institutional nodes, amendment pressure points, and live disputes that genuinely connect them."
		presets={defaultGraphPresets}
	/>

	<section class="section-block">
		<div class="section-heading">
			<div>
				<p class="eyebrow">Start Here</p>
				<h2>Browse the constitutional map</h2>
			</div>
			<p class="section-note">The reference layer anchors the live explainers.</p>
		</div>
		<div class="feature-grid">
			<a class="feature-tile" href={withBase('/articles')}>
				<span>Articles</span>
				<strong>{articles.length} constitutional provisions</strong>
				<p>Plain-English summaries, related cases, and linked issue pages.</p>
			</a>
			<a class="feature-tile" href={withBase('/parts')}>
				<span>Parts</span>
				<strong>{parts.length} structural divisions</strong>
				<p>Read rights, emergency powers, and amendment logic in constitutional context.</p>
			</a>
			<a class="feature-tile" href={withBase('/schedules')}>
				<span>Schedules</span>
				<strong>{schedules.length} operational annexes</strong>
				<p>Surface the lists and frameworks that make the text work in practice.</p>
			</a>
			<a class="feature-tile" href={withBase('/topics')}>
				<span>Topics</span>
				<strong>{topics.length} thematic hubs</strong>
				<p>Use broad themes like federalism and fundamental rights to navigate.</p>
			</a>
			<a class="feature-tile" href={withBase('/institutions')}>
				<span>Institutions</span>
				<strong>{institutions.length} constitutional actors</strong>
				<p>Follow Parliament, the Court, ECI, governors, and other actors behind live disputes.</p>
			</a>
			<a class="feature-tile" href={withBase('/sources')}>
				<span>Sources</span>
				<strong>{sources.length} registered source profiles</strong>
				<p>See which official, court, policy, and reference sources the site relies on and when each should be used.</p>
			</a>
			<a class="feature-tile" href={withBase('/cases')}>
				<span>Landmark Cases</span>
				<strong>{cases.length} foundational judgments</strong>
				<p>See how doctrine and interpretation shape constitutional meaning.</p>
			</a>
			<a class="feature-tile" href={withBase('/amendments')}>
				<span>Amendments</span>
				<strong>{amendments.length} constitutional changes</strong>
				<p>Track how the document evolved and which Articles were affected.</p>
			</a>
			<a class="feature-tile" href={withBase('/glossary')}>
				<span>Glossary</span>
				<strong>{glossary.length} plain-English terms</strong>
				<p>Decode doctrinal language without leaving the reading flow.</p>
			</a>
			<a class="feature-tile" href={withBase('/timeline')}>
				<span>Timeline</span>
				<strong>{timeline.length} turning points</strong>
				<p>See how cases, crises, and amendments changed constitutional meaning.</p>
			</a>
			<a class="feature-tile" href={withBase('/graph')}>
				<span>Graph</span>
				<strong>Interactive relationship explorer</strong>
				<p>See Articles, institutions, cases, amendments, and live issues as one connected map.</p>
			</a>
			<a class="feature-tile" href={withBase('/search')}>
				<span>Search</span>
				<strong>Cross-site lookup</strong>
				<p>Find Articles, Parts, cases, schedules, current affairs, and glossary terms.</p>
			</a>
		</div>
	</section>

	<section class="section-block">
		<div class="section-heading">
			<div>
				<p class="eyebrow">Institutions</p>
				<h2>Follow the constitutional actors</h2>
			</div>
			<a class="section-link" href={withBase('/institutions')}>See all Institutions</a>
		</div>
		<div class="card-grid">
			{
				featuredInstitutions.map((item) => (
					<ContentCard
						eyebrow="Institution"
						title={item.data.title}
						description={item.data.summary}
						href={getEntryHref('institutions', item.data.slug)}
					/>
				))
			}
		</div>
	</section>

	<section class="section-block">
		<div class="section-heading">
			<div>
				<p class="eyebrow">Articles</p>
				<h2>Core provisions</h2>
			</div>
			<a class="section-link" href={withBase('/articles')}>See all Articles</a>
		</div>
		<div class="card-grid">
			{
				featuredArticles.map((article) => (
					<ContentCard
						eyebrow={`Article ${article.data.number}`}
						title={article.data.title}
						description={article.data.summary}
						href={getEntryHref('articles', article.data.slug)}
						meta={article.data.part}
					/>
				))
			}
		</div>
	</section>

	<section class="section-block">
		<div class="section-heading">
			<div>
				<p class="eyebrow">Topics</p>
				<h2>Browse by constitutional theme</h2>
			</div>
			<a class="section-link" href={withBase('/topics')}>See all Topics</a>
		</div>
		<div class="card-grid">
			{
				featuredTopics.map((topic) => (
					<ContentCard
						eyebrow="Topic"
						title={topic.data.title}
						description={topic.data.summary}
						href={getEntryHref('topics', topic.data.slug)}
					/>
				))
			}
		</div>
	</section>

	<section class="section-split">
		<div class="section-panel">
			<div class="section-heading compact">
				<div>
					<p class="eyebrow">Parts</p>
					<h2>Read the constitutional structure</h2>
				</div>
				<a class="section-link" href={withBase('/parts')}>See all</a>
			</div>
			<div class="stack">
				{
					featuredParts.map((part) => (
						<ContentCard
							eyebrow={part.data.code}
							title={part.data.title}
							description={part.data.summary}
							href={getEntryHref('parts', part.data.slug)}
						/>
					))
				}
			</div>
		</div>
		<div class="section-panel">
			<div class="section-heading compact">
				<div>
					<p class="eyebrow">Schedules</p>
					<h2>Reference the working detail</h2>
				</div>
				<a class="section-link" href={withBase('/schedules')}>See all</a>
			</div>
			<div class="stack">
				{
					featuredSchedules.map((schedule) => (
						<ContentCard
							eyebrow={`Schedule ${schedule.data.number}`}
							title={schedule.data.title}
							description={schedule.data.summary}
							href={getEntryHref('schedules', schedule.data.slug)}
						/>
					))
				}
			</div>
		</div>
	</section>

	<section class="section-split">
		<div class="section-panel">
			<div class="section-heading compact">
				<div>
					<p class="eyebrow">Cases</p>
					<h2>Landmark judgments</h2>
				</div>
				<a class="section-link" href={withBase('/cases')}>View all</a>
			</div>
			<div class="stack">
				{
					featuredCases.map((item) => (
						<ContentCard
							eyebrow={item.data.year.toString()}
							title={item.data.title}
							description={item.data.summary}
							href={getEntryHref('cases', item.data.slug)}
							meta={item.data.citation}
						/>
					))
				}
			</div>
		</div>
		<div class="section-panel">
			<div class="section-heading compact">
				<div>
					<p class="eyebrow">Current Affairs</p>
					<h2>Live constitutional explainers</h2>
				</div>
				<a class="section-link" href={withBase('/current-affairs')}>Track all</a>
			</div>
			<div class="stack">
				{
					latestCurrentAffairs.map((item) => (
						<ContentCard
							eyebrow={titleCaseStatus(item.data.status)}
							title={item.data.title}
							description={item.data.summary}
							href={getEntryHref('current-affairs', item.data.slug)}
							meta={`Updated ${formatDate(item.data.updatedAt)} · Official-source anchored`}
						/>
					))
				}
			</div>
		</div>
	</section>

	<section class="section-split">
		<div class="section-panel">
			<div class="section-heading compact">
				<div>
					<p class="eyebrow">Glossary</p>
					<h2>Decode constitutional language</h2>
				</div>
				<a class="section-link" href={withBase('/glossary')}>Browse all</a>
			</div>
			<div class="stack">
				{
					featuredGlossary.map((term) => (
						<ContentCard
							eyebrow="Glossary"
							title={term.data.title}
							description={term.data.summary}
							href={getEntryHref('glossary', term.data.slug)}
						/>
					))
				}
			</div>
		</div>
		<div class="section-panel">
			<div class="section-heading compact">
				<div>
					<p class="eyebrow">Sources</p>
					<h2>Trust and verification layer</h2>
				</div>
				<a class="section-link" href={withBase('/sources')}>Open source registry</a>
			</div>
			<div class="stack">
				{
					featuredSources.map((item) => (
						<ContentCard
							eyebrow={`${humanizeToken(item.data.tier)} · ${humanizeToken(item.data.sourceType)}`}
							title={item.data.title}
							description={item.data.description}
							href={getEntryHref('sources', item.data.slug)}
							meta={item.data.publisher}
						/>
					))
				}
			</div>
		</div>
	</section>

	<section class="section-block">
		<div class="section-heading">
			<div>
				<p class="eyebrow">Timeline</p>
				<h2>Major turning points</h2>
			</div>
			<a class="section-link" href={withBase('/timeline')}>Open timeline</a>
		</div>
		<div class="stack">
			{
				featuredTimeline.map((item) => (
					<a class="search-result" href={withBase(`/timeline#${item.data.slug}`)}>
						<p class="eyebrow">{formatDate(item.data.date)}</p>
						<strong>{item.data.title}</strong>
						<p>{item.data.summary}</p>
					</a>
				))
			}
		</div>
	</section>

	<section class="section-block">
		<div class="section-heading">
			<div>
				<p class="eyebrow">Amendments</p>
				<h2>Constitutional change over time</h2>
			</div>
			<a class="section-link" href={withBase('/amendments')}>See amendment archive</a>
		</div>
		<div class="timeline-strip">
			{
				featuredAmendments.map((amendment) => (
					<a class="timeline-tile" href={getEntryHref('amendments', amendment.data.slug)}>
						<span>{amendment.data.year}</span>
						<strong>{amendment.data.title}</strong>
						<p>{amendment.data.summary}</p>
					</a>
				))
			}
		</div>
	</section>
</Layout>
