---
import GraphExplorer from '../../components/GraphExplorer.astro';
import PageIntro from '../../components/PageIntro.astro';
import SearchSignals from '../../components/SearchSignals.astro';
import Layout from '../../layouts/Layout.astro';
import { defaultGraphPresets } from '../../lib/graph-presets';
import { getGraphExplorerData } from '../../lib/graph';
import { withBase } from '../../lib/content';

const backboneGraph = await getGraphExplorerData({ profile: 'home' });
const expandedGraph = await getGraphExplorerData({ profile: 'display' });
---

<Layout
	title="Relationship Explorer | Constitution Atlas"
	description="Explore a curated constitutional knowledge graph linking Articles, cases, amendments, institutions, and live issues through typed relationships."
	pagefindIndexed={true}
>
	<PageIntro
		eyebrow="Graph"
		title="Explore the constitutional intelligence graph"
		summary="This explorer focuses on the high-signal constitutional graph: doctrine, constitutional text, amendments, institutions, and live disputes with typed, source-backed relationships."
		meta={['Focused graph modes', 'Typed constitutional relationships', 'Source-backed explicit edges']}
		breadcrumbs={[
			{ label: 'Home', href: '/' },
			{ label: 'Relationship Explorer' },
		]}
	/>
	<SearchSignals
		meta={{
			type: 'Page',
			summary: 'Interactive constitutional graph with overview, focus, and path modes linking text, doctrine, institutions, history, and live issues.',
			subtitle: 'Relationship Explorer',
		}}
		filters={{
			type: 'Page',
		}}
	/>

	<section class="list-shell graph-page-copy" data-pagefind-body>
		<div class="filter-row graph-scope-nav" data-pagefind-ignore>
			<a class="filter-pill is-active" href={withBase('/graph')}>Expanded Explorer</a>
			<a class="filter-pill" href={withBase('/graph/backbone')}>Backbone View</a>
		</div>
		<p>
			Start in Overview mode to see the strongest constitutional anchors, then switch scopes inside the explorer
			when you want a tighter backbone or a broader dossier. Path mode favors explainable constitutional routes over
			weak editorial cross-links.
		</p>
	</section>

	<GraphExplorer
		datasets={{
			backbone: {
				label: 'Backbone',
				description: 'Highest-signal doctrine, constitutional anchors, institutions, reforms, and live disputes only.',
				nodes: backboneGraph.nodes,
				edges: backboneGraph.edges,
				directedEdges: backboneGraph.directedEdges,
				stats: backboneGraph.stats,
				legend: backboneGraph.legend,
				metrics: backboneGraph.metrics,
				communities: backboneGraph.communities,
			},
			expanded: {
				label: 'Expanded',
				description: 'Broader constitutional neighborhood with more supporting pages, context, and bridge nodes.',
				nodes: expandedGraph.nodes,
				edges: expandedGraph.edges,
				directedEdges: expandedGraph.directedEdges,
				stats: expandedGraph.stats,
				legend: expandedGraph.legend,
				metrics: expandedGraph.metrics,
				communities: expandedGraph.communities,
			},
		}}
		defaultScope="expanded"
		presets={defaultGraphPresets}
	/>
</Layout>
