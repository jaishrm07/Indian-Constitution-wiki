---
import GraphExplorer from '../../components/GraphExplorer.astro';
import PageIntro from '../../components/PageIntro.astro';
import SearchSignals from '../../components/SearchSignals.astro';
import Layout from '../../layouts/Layout.astro';
import { defaultGraphPresets } from '../../lib/graph-presets';
import { getGraphExplorerData } from '../../lib/graph';

const graph = await getGraphExplorerData();
---

<Layout
	title="Relationship Explorer | Constitution Atlas"
	description="Explore the constitutional knowledge graph linking Articles, cases, amendments, institutions, glossary terms, timelines, and live issues."
	pagefindIndexed={true}
>
	<PageIntro
		eyebrow="Graph"
		title="Explore the constitutional intelligence graph"
		summary="This explorer turns the site into a typed knowledge graph so readers can trace doctrine, constitutional text, amendments, institutions, glossary terms, and live disputes as one connected system."
		meta={['Focused graph modes', 'Typed constitutional relationships', 'Source-backed explicit edges']}
		breadcrumbs={[
			{ label: 'Home', href: '/' },
			{ label: 'Relationship Explorer' },
		]}
	/>
	<SearchSignals
		meta={{
			type: 'Page',
			summary: 'Interactive constitutional graph with overview, focus, and path modes linking text, doctrine, institutions, history, and live issues.',
			subtitle: 'Relationship Explorer',
		}}
		filters={{
			type: 'Page',
		}}
	/>

	<section class="list-shell graph-page-copy" data-pagefind-body>
		<p>
			Start in Overview mode to see the most connected constitutional anchors, switch to Focus mode for a node-centered
			dossier, and use Path mode when you need the shortest explainable route between two constitutional ideas.
		</p>
	</section>

	<GraphExplorer nodes={graph.nodes} edges={graph.edges} stats={graph.stats} legend={graph.legend} presets={defaultGraphPresets} />
</Layout>
