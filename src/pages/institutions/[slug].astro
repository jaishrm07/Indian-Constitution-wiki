---
import { getCollection, render } from 'astro:content';
import ContentCard from '../../components/ContentCard.astro';
import ConstitutionRefs from '../../components/ConstitutionRefs.astro';
import PageIntro from '../../components/PageIntro.astro';
import SearchSignals from '../../components/SearchSignals.astro';
import Layout from '../../layouts/Layout.astro';
import {
	filterByAnyRelationship,
	filterByRelationship,
	formatDate,
	getEntryHref,
	humanizeToken,
	resolveBySlugs,
	sortArticles,
	sortByDateDesc,
	uniqueBySlug,
} from '../../lib/content';

export async function getStaticPaths() {
	const institutions = await getCollection('institutions');
	return institutions.map((entry) => ({
		params: { slug: entry.data.slug },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const [articles, parts, topics, cases, currentAffairs, sources] = await Promise.all([
	getCollection('articles'),
	getCollection('parts'),
	getCollection('topics'),
	getCollection('cases'),
	getCollection('current-affairs'),
	getCollection('sources'),
]);

const relatedArticles = resolveBySlugs(articles, entry.data.articles);
const relatedParts = resolveBySlugs(parts, entry.data.parts);
const relatedTopics = uniqueBySlug([
	...resolveBySlugs(topics, entry.data.topics),
	...filterByAnyRelationship(topics, 'sources', entry.data.sources),
]);
const relatedCases = uniqueBySlug([
	...resolveBySlugs(cases, entry.data.cases),
	...filterByAnyRelationship(cases, 'sources', entry.data.sources),
]);
const relatedCurrentAffairs = uniqueBySlug([
	...resolveBySlugs(currentAffairs, entry.data.currentAffairs),
	...filterByRelationship(currentAffairs, 'institutions', entry.data.slug),
]);
const relatedSources = uniqueBySlug([
	...resolveBySlugs(sources, entry.data.sources),
	...filterByRelationship(sources, 'institutions', entry.data.slug),
]);
const orderedCurrentAffairs = sortByDateDesc(relatedCurrentAffairs, 'updatedAt');
const ongoingCurrentAffairs = orderedCurrentAffairs.filter((item) => item.data.status === 'ongoing');
const historicalCurrentAffairs = orderedCurrentAffairs.filter((item) => item.data.status !== 'ongoing');
const sourceGroups = [
	{
		title: 'Official constitutional and institutional records',
		items: relatedSources.filter((source) => source.data.sourceType === 'official'),
	},
	{
		title: 'Court-hosted records and judgments',
		items: relatedSources.filter((source) => source.data.sourceType === 'court'),
	},
	{
		title: 'Context and monitoring sources',
		items: relatedSources.filter((source) => source.data.sourceType !== 'official' && source.data.sourceType !== 'court'),
	},
].filter((group) => group.items.length > 0);
const orderedArticles = sortArticles(relatedArticles);
---

<Layout title={`${entry.data.title} | Constitution Atlas`} description={entry.data.summary} pagefindIndexed={true}>
	<PageIntro
		eyebrow="Institution"
		title={entry.data.title}
		summary={entry.data.summary}
		meta={[humanizeToken(entry.data.institutionType)]}
		breadcrumbs={[
			{ label: 'Home', href: '/' },
			{ label: 'Institutions', href: '/institutions' },
			{ label: entry.data.title },
		]}
	/>
	<SearchSignals
		meta={{
			type: 'Institution',
			summary: entry.data.summary,
			subtitle: humanizeToken(entry.data.institutionType),
		}}
		filters={{
			type: 'Institution',
			topic: relatedTopics.map((topic) => topic.data.title),
			institution: entry.data.title,
			category: humanizeToken(entry.data.institutionType),
		}}
	/>

	<section class="page-grid">
		<article class="page-copy prose" data-pagefind-body>
			<section>
				<h2>Constitutional role</h2>
				<p>{entry.data.role}</p>
			</section>
			<section>
				<h2>Why it matters</h2>
				<p>{entry.data.whyItMatters}</p>
			</section>
			{entry.data.constitutionalBasis.length > 0 && (
				<section>
					<h2>Constitutional basis</h2>
					<ul>
						{entry.data.constitutionalBasis.map((item) => <li>{item}</li>)}
					</ul>
				</section>
			)}
			{ongoingCurrentAffairs.length > 0 && (
				<section>
					<h2>Current constitutional pressure points</h2>
					<div class="stack">
						{ongoingCurrentAffairs.map((item) => (
							<a class="search-result" href={getEntryHref('current-affairs', item.data.slug)}>
								<p class="eyebrow">Updated {formatDate(item.data.updatedAt)}</p>
								<strong>{item.data.title}</strong>
								<p>{item.data.constitutionalQuestion}</p>
							</a>
						))}
					</div>
				</section>
			)}
			{orderedArticles.length > 0 && (
				<section>
					<h2>Constitutional anchor provisions</h2>
					<div class="card-grid card-grid--compact">
						{orderedArticles.map((item) => <ContentCard eyebrow={`Article ${item.data.number}`} title={item.data.title} description={item.data.summary} href={getEntryHref('articles', item.data.slug)} meta={item.data.part} />)}
					</div>
				</section>
			)}
			<Content />
		</article>

		<aside class="page-sidebar">
			<div class="info-panel">
				<h3>Desk coverage</h3>
				<ul class="detail-list">
					<li>{ongoingCurrentAffairs.length} ongoing issue{ongoingCurrentAffairs.length === 1 ? '' : 's'}</li>
					<li>{historicalCurrentAffairs.length} resolved or archived issue{historicalCurrentAffairs.length === 1 ? '' : 's'}</li>
					<li>{relatedCases.length} linked case{relatedCases.length === 1 ? '' : 's'}</li>
				</ul>
			</div>
			<ConstitutionRefs
				parts={relatedParts.map((part) => ({ title: part.data.code, href: getEntryHref('parts', part.data.slug) }))}
				articles={relatedArticles.map((article) => ({ title: `Article ${article.data.number}`, href: getEntryHref('articles', article.data.slug) }))}
			/>
			{
				sourceGroups.map((group) => (
					<div class="info-panel">
						<h3>{group.title}</h3>
						<ul class="source-list">
							{
								group.items.map((source) => (
									<li>
										<a href={getEntryHref('sources', source.data.slug)}>{source.data.title}</a>
										<a class="source-list__external" href={source.data.url} target="_blank" rel="noreferrer">Open source</a>
										<small>{humanizeToken(source.data.tier)} · {humanizeToken(source.data.sourceType)}</small>
									</li>
								))
							}
						</ul>
					</div>
				))
			}
		</aside>
	</section>

	{ongoingCurrentAffairs.length > 0 && (
		<section class="section-block">
			<div class="section-heading">
				<div>
					<p class="eyebrow">Current Affairs</p>
					<h2>Live constitutional issues involving this institution</h2>
				</div>
			</div>
			<div class="card-grid">
				{ongoingCurrentAffairs.map((item) => <ContentCard eyebrow="Current Affairs" title={item.data.title} description={item.data.summary} href={getEntryHref('current-affairs', item.data.slug)} meta={`Updated ${formatDate(item.data.updatedAt)}`} />)}
			</div>
		</section>
	)}

	{(relatedTopics.length > 0 || relatedCases.length > 0) && (
		<section class="section-split">
			{relatedTopics.length > 0 && (
				<div class="section-panel">
					<div class="section-heading compact">
						<div>
							<p class="eyebrow">Topics</p>
							<h2>Doctrinal areas</h2>
						</div>
					</div>
					<div class="stack">
						{relatedTopics.map((item) => <ContentCard eyebrow="Topic" title={item.data.title} description={item.data.summary} href={getEntryHref('topics', item.data.slug)} />)}
					</div>
				</div>
			)}
			{relatedCases.length > 0 && (
				<div class="section-panel">
					<div class="section-heading compact">
						<div>
							<p class="eyebrow">Cases</p>
							<h2>Important judgments</h2>
						</div>
					</div>
					<div class="stack">
						{relatedCases.map((item) => <ContentCard eyebrow={item.data.year.toString()} title={item.data.title} description={item.data.summary} href={getEntryHref('cases', item.data.slug)} meta={item.data.citation} />)}
					</div>
				</div>
			)}
		</section>
	)}

	{historicalCurrentAffairs.length > 0 && (
		<section class="section-block">
			<div class="section-heading">
				<div>
					<p class="eyebrow">History</p>
					<h2>Earlier constitutional issues involving this institution</h2>
				</div>
			</div>
			<div class="card-grid">
				{historicalCurrentAffairs.map((item) => <ContentCard eyebrow={humanizeToken(item.data.status)} title={item.data.title} description={item.data.summary} href={getEntryHref('current-affairs', item.data.slug)} meta={`Updated ${formatDate(item.data.updatedAt)}`} />)}
			</div>
		</section>
	)}
</Layout>
