---
interface GraphSourceRef {
	slug: string;
	title: string;
	href: string;
}

interface GraphEvidenceItem {
	claim: string;
	note: string;
	passage?: string;
	location?: string;
	direction: 'source-to-target' | 'target-to-source' | 'both';
	sources: string[];
	sourceRefs: GraphSourceRef[];
	weight: number;
}

interface GraphNode {
	id: string;
	label: string;
	subtitle: string;
	summary: string;
	type: string;
	collection: string;
	slug: string;
	href: string;
	degree: number;
	inDegree?: number;
	outDegree?: number;
	weightedDegree?: number;
	pagerank?: number;
	bridgeScore?: number;
	communityId?: number;
	communitySize?: number;
	importance?: number;
	overview: boolean;
	explicitlyConnected: boolean;
}

interface GraphEdgeRelation {
	from: string;
	to: string;
	relationType: string;
	relationLabel: string;
	explicit: boolean;
	directional: boolean;
	direction: 'forward' | 'reverse' | 'bidirectional' | 'mixed';
	note?: string;
	sources: string[];
	sourceRefs: GraphSourceRef[];
	evidence: GraphEvidenceItem[];
	strength: number;
}

interface GraphEdge {
	id: string;
	source: string;
	target: string;
	family: string;
	familyLabel: string;
	familyDescription: string;
	familyColor: string;
	relationLabels: string[];
	relationTypes: string[];
	relations: GraphEdgeRelation[];
	explicit: boolean;
	directional: boolean;
	direction: 'forward' | 'reverse' | 'bidirectional' | 'mixed';
	dominantSource: string;
	dominantTarget: string;
	note: string;
	sourceCount: number;
	evidenceCount: number;
	weight: number;
}

interface GraphDirectedEdge {
	id: string;
	source: string;
	target: string;
	relationType: string;
	relationLabel: string;
	family: string;
	familyLabel: string;
	familyColor: string;
	explicit: boolean;
	note: string;
	strength: number;
	sourceCount: number;
	sourceRefs: GraphSourceRef[];
	evidence: GraphEvidenceItem[];
	edgeId: string;
	reversed: boolean;
}

interface GraphStat {
	label: string;
	value: number;
	href?: string;
}

interface GraphLegendItem {
	family: string;
	label: string;
	description: string;
	color: string;
	count: number;
}

interface GraphCommunity {
	id: number;
	size: number;
	label: string;
	members: string[];
	anchors: string[];
}

interface GraphMetrics {
	nodeCount: number;
	edgeCount: number;
	directedEdgeCount: number;
	explicitEdgeCount: number;
	overviewNodeCount: number;
	communityCount: number;
	bridgeNodeCount: number;
	averageDegree: number;
	averageImportance: number;
	topCentralNodes: string[];
	topBridgeNodes: string[];
}

interface GraphPreset {
	id: string;
	label: string;
	description: string;
	startId: string;
	targetId?: string;
	mode?: 'explore' | 'path';
	depth?: 1 | 2;
	filter?: string;
	accent?: string;
}

interface GraphDataset {
	label: string;
	description?: string;
	nodes: GraphNode[];
	edges: GraphEdge[];
	directedEdges: GraphDirectedEdge[];
	stats: GraphStat[];
	legend: GraphLegendItem[];
	metrics: GraphMetrics;
	communities: GraphCommunity[];
}

interface Props {
	nodes?: GraphNode[];
	edges?: GraphEdge[];
	directedEdges?: GraphDirectedEdge[];
	stats?: GraphStat[];
	legend?: GraphLegendItem[];
	metrics?: GraphMetrics;
	communities?: GraphCommunity[];
	datasets?: Record<string, GraphDataset>;
	defaultScope?: string;
	variant?: 'default' | 'home';
	eyebrow?: string;
	title?: string;
	summary?: string;
	presets?: GraphPreset[];
}

const EMPTY_METRICS: GraphMetrics = {
	nodeCount: 0,
	edgeCount: 0,
	directedEdgeCount: 0,
	explicitEdgeCount: 0,
	overviewNodeCount: 0,
	communityCount: 0,
	bridgeNodeCount: 0,
	averageDegree: 0,
	averageImportance: 0,
	topCentralNodes: [],
	topBridgeNodes: [],
};

const {
	nodes = [],
	edges = [],
	directedEdges = [],
	stats = [],
	legend = [],
	metrics = EMPTY_METRICS,
	communities = [],
	datasets,
	defaultScope,
	variant = 'default',
	eyebrow,
	title,
	summary,
	presets = [],
} = Astro.props;

const normalizedDatasets =
	datasets && Object.keys(datasets).length > 0
		? datasets
		: {
				default: {
					label: 'Graph',
					nodes,
					edges,
					directedEdges,
					stats,
					legend,
					metrics,
					communities,
				},
			};

const datasetEntries = Object.entries(normalizedDatasets);
const initialScope = defaultScope && normalizedDatasets[defaultScope] ? defaultScope : datasetEntries[0][0];
const activeDataset = normalizedDatasets[initialScope];
const filterTypes = ['All', ...new Set(activeDataset.nodes.map((node) => node.type))];
const nodeOptions = [...activeDataset.nodes].sort((left, right) => {
	if (left.type !== right.type) {
		return left.type.localeCompare(right.type);
	}

	const rightScore = (right.importance ?? 0) * 100 + (right.bridgeScore ?? 0) * 40 + right.degree;
	const leftScore = (left.importance ?? 0) * 100 + (left.bridgeScore ?? 0) * 40 + left.degree;
	if (rightScore !== leftScore) {
		return rightScore - leftScore;
	}

	return left.label.localeCompare(right.label);
});
---

<section class:list={['graph-shell', { 'graph-shell--home': variant === 'home' }]} data-graph-shell data-graph-variant={variant}>
	<div class="graph-main">
		{
			(eyebrow || title || summary) && (
				<div class="graph-stage">
					<div class="graph-stage__copy">
						{eyebrow && <p class="eyebrow">{eyebrow}</p>}
						{title && <h2>{title}</h2>}
						{summary && <p class="graph-stage__summary">{summary}</p>}
					</div>
					<div class="graph-stage__metrics" data-graph-stage-metrics>
						{activeDataset.stats.slice(0, 3).map((stat) => (
							<div class="graph-stage__metric">
								<strong>{stat.value}</strong>
								<span>{stat.label}</span>
							</div>
						))}
					</div>
				</div>
			)
		}

		{
			presets.length > 0 && (
				<div class="graph-presets-shell">
					<div class="graph-presets-shell__copy">
						<strong>Guided entry points</strong>
						<p>Open one constitutional story first, then branch outward once the map has context.</p>
					</div>
					<div class="graph-presets" data-graph-presets>
						{presets.map((preset, index) => (
							<button
								type="button"
								class:list={['graph-preset', { 'is-active': index === 0 }]}
								data-graph-preset={preset.id}
								data-graph-preset-start-id={preset.startId}
								data-graph-preset-target-id={preset.targetId}
								data-graph-preset-mode={preset.mode ?? 'explore'}
								data-graph-preset-depth={preset.depth ?? 1}
								data-graph-preset-filter={preset.filter ?? 'All'}
								style={preset.accent ? `--graph-preset-accent:${preset.accent}` : undefined}
							>
								<span class="graph-preset__kicker">Preset</span>
								<strong>{preset.label}</strong>
								<p>{preset.description}</p>
							</button>
						))}
					</div>
				</div>
			)
		}

		<div class="graph-toolbar">
			{
				datasetEntries.length > 1 && (
					<div class="graph-toolbar__row graph-toolbar__row--modes">
						<div class="graph-toolbar__cluster graph-toolbar__cluster--wide">
							<span class="graph-toolbar__label">Scope</span>
							<div class="graph-mode-switch" data-graph-scopes>
								{datasetEntries.map(([scopeId, dataset]) => (
									<button
										type="button"
										class:list={['filter-pill', { 'is-active': scopeId === initialScope }]}
										data-graph-scope={scopeId}
										title={dataset.description}
									>
										{dataset.label}
									</button>
								))}
							</div>
							<p class="graph-toolbar__hint" data-graph-scope-summary>{activeDataset.description ?? `Currently showing the ${activeDataset.label.toLowerCase()}.`}</p>
						</div>
					</div>
				)
			}

			<div class="graph-toolbar__row graph-toolbar__row--modes">
				<div class="graph-toolbar__cluster">
					<span class="graph-toolbar__label">Mode</span>
					<div class="graph-mode-switch" data-graph-modes>
						<button type="button" class:list={['filter-pill', 'is-active']} data-graph-mode="explore">Explore</button>
						<button type="button" class="filter-pill" data-graph-mode="path">Shortest path</button>
					</div>
				</div>
				<div class="graph-toolbar__cluster">
					<span class="graph-toolbar__label">Layout</span>
					<div class="graph-mode-switch" data-graph-layouts>
						<button type="button" class:list={['filter-pill', 'is-active']} data-graph-layout="organic">Organic</button>
						<button type="button" class="filter-pill" data-graph-layout="layered">Layered</button>
						<button type="button" class="filter-pill" data-graph-layout="timeline">Timeline</button>
					</div>
				</div>
				<div class="graph-toolbar__cluster">
					<span class="graph-toolbar__label">Depth</span>
					<div class="graph-depth-switch" data-graph-depths>
						<button type="button" class:list={['filter-pill', 'is-active']} data-graph-depth="1">1 hop</button>
						<button type="button" class="filter-pill" data-graph-depth="2">2 hops</button>
					</div>
				</div>
				<button type="button" class="button-secondary graph-reset" data-graph-reset>Reset view</button>
			</div>

			<div class="graph-field-grid">
				<label class="graph-field">
					<span>Focus node</span>
					<input list="graph-node-options" type="search" placeholder="Article 21, Kesavananda Bharati, privacy..." data-graph-start />
				</label>
				<label class="graph-field graph-field--target is-hidden" data-graph-target-field>
					<span>Path target</span>
					<input list="graph-node-options" type="search" placeholder="Pick another node to trace the shortest path..." data-graph-target />
				</label>
			</div>

			<datalist id="graph-node-options" data-graph-node-options>
				{
					nodeOptions.map((node) => (
						<option value={node.label} label={`${node.type} • ${node.subtitle}`} />
					))
				}
			</datalist>

			<div class="graph-filters" data-graph-filters>
				{
					filterTypes.map((type) => (
						<button type="button" class:list={['filter-pill', { 'is-active': type === 'All' }]} data-graph-filter={type}>
							{type}
						</button>
					))
				}
			</div>

			<div class="graph-legend-shell">
				<div class="graph-legend-shell__copy">
					<strong>Relationship families</strong>
					<p>Color tells you whether a connection comes from constitutional structure, doctrine, reform, live practice, or history.</p>
				</div>
				<div class="graph-legend" data-graph-legend>
					{
						activeDataset.legend.map((item) => (
							<div class="graph-legend__item" title={item.description}>
								<span class="graph-legend__swatch" style={`--legend-color:${item.color}`}></span>
								<div>
									<strong>{item.label}</strong>
									<small>{item.count} edges</small>
								</div>
							</div>
						))
					}
				</div>
			</div>
		</div>

		<div class="graph-canvas-frame">
			<div class="graph-view-summary" data-graph-view-summary>
				Showing the curated overview. Select a node to open a tighter constitutional neighborhood.
			</div>
			<div class="graph-canvas" data-graph-canvas></div>
		</div>
	</div>

	<aside class="graph-aside">
		<div class="graph-stats" data-graph-stats>
			{
				activeDataset.stats.map((stat) =>
					stat.href ? (
						<a class="stat-card" href={stat.href}>
							<strong>{stat.value}</strong>
							<span>{stat.label}</span>
						</a>
					) : (
						<div class="stat-card">
							<strong>{stat.value}</strong>
							<span>{stat.label}</span>
						</div>
					),
				)
			}
		</div>

		<div class="graph-detail" data-graph-detail>
			<p class="eyebrow">Active Focus</p>
			<h2 data-detail-title>Curated overview</h2>
			<p class="graph-detail__summary" data-detail-summary>
				Start with a case, Article, or live desk. The graph will collapse into a focused neighborhood instead of
				showing the whole network at once.
			</p>
			<p class="graph-detail__meta" data-detail-meta>Overview mode • core constitutional nodes only</p>
			<div class="graph-detail__chips" data-detail-chips></div>
			<div class="graph-detail__panel" data-detail-panel>
				<p class="muted">Typed edges are color-coded by family and direction so you can tell structure, doctrine, reform, live dispute, and history apart.</p>
			</div>
			<a class="button-secondary graph-detail__cta is-disabled" href="#" data-detail-link aria-disabled="true">Open page</a>
		</div>
	</aside>

	<script
		type="application/json"
		data-graph-payload
		set:html={JSON.stringify({ datasets: normalizedDatasets, initialScope })}
	/>
</section>

<script>
	import { mountGraphExplorer } from '../lib/graph-runtime';

	document.querySelectorAll('[data-graph-shell]').forEach((root) => {
		if (root instanceof HTMLElement) {
			mountGraphExplorer(root);
		}
	});
</script>
